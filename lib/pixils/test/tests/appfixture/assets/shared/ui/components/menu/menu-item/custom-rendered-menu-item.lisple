(ns pixils.test.app.minesweeper.core
  (:require pixils
            [pixils.render :as r]
            [pixils.test.app.minesweeper.menu-definition :as md]))

(defcomponent menu-item
  {:style {:padding 2
           :hover {:background {:r 90 :g 90 :b 110}}}
   :on-mouse-down (fn [state event ctx]
                    (push-mode!
                     'popup-menu-mode
                     {}
                     {:children [{:mode 'popup-menu-mode
                                  :style {:position :absolute
                                          :background {:r 255 :g 255 :b 255}
                                          :border {:thickness 1
                                                   :line-style :solid
                                                   :color {:r 0 :g 0 :b 0}}
                                          :left (-> ctx :view :bounds :x)
                                          :top (+ (-> ctx :view :bounds :y)
                                                  (-> ctx :view :bounds :h))
                                          :width (+ 8
                                                    (apply max
                                                           (map (:items state)
                                                                (fn [item]
                                                                  (:w (r/text-size (:title item)
                                                                                   {:font :font/win3-system-font}))))))
                                          :height (* (+ 4 md/menu-item-h)
                                                     (-> state :items count))}
                                  :children (for-indexed [n item (:items state)]
                                              (make-menu-item item
                                                              {:x (* n md/menu-item-w)
                                                               :y 0
                                                               :w md/menu-item-w
                                                               :h md/menu-item-h}))}]})
                    state)
   :render (fn [state ctx]
             (r/text! (:text state)
                      {:x 0 :y 0}
                      {:scale 1
                       :font :font/win3-system-font
                       :color {:r 0 :g 0 :b 0}}))})

(defun make-menu-item [item bounds]
  {:mode 'menu-item
   :style {:width (:w bounds)
           :height (:h bounds)}
   :state {:text (:title item)
           :items (:items item)}})
