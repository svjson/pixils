(ns pixils.test.app.minesweeper.game-logic)

(defun new-game-state [w h mines]
  {:settings {:w w
              :h h
              :mines mines}
   :face :status/face-normal
   :board (generate-mine-field w h mines)
   :board-mask (dotimes [y h]
                 (dotimes [x w]
                   {:revealed? false
                    :flagged? false}))
   :start-time (epoch-ms)
   :counters {:mines-left mines
              :timer 0}})
