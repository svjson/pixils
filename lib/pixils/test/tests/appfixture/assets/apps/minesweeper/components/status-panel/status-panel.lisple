(ns pixils.test.app.minesweeper.core
  (:require pixils
            [pixils.ui :as ui]
            pixils.test.app.shared.ui.components.button))

(defcomponent status-panel {:style {:width :fill
                                    :height 25
                                    :padding 4
                                    :layout {:direction :row
                                             :gap :space-between}}
                            :children [{:mode 'counter
                                        :state {:value (ui/bind-state :counters :mines-left)}}

                                       {:mode 'button
                                        :style {:width 24
                                                :height 24}
                                        :state {:image (ui/bind-state :face)}
                                        :on-click (fn [state event ctx]
                                                    (when (= :left (:button event))
                                                      (ui/emit! (:view ctx) :game/new-game))
                                                    state)}

                                       {:mode 'counter
                                        :state {:value (ui/bind-state :counters :timer)}}]})
