(ns pixils.test.app.minesweeper.core
  (:require pixils))

(deffont counter-font
  {:type :bitmap
   :spacing 0
   :resource :status-panel/counter-font-map
   :glyphs (reduce "0123456789"
                   {}
                   (fn [glyphs num]
                     (let [index (int (str num))]
                       (merge glyphs
                              {num {:x (* index 13)
                                    :y 0
                                    :w 13
                                    :h 23}}))))})
