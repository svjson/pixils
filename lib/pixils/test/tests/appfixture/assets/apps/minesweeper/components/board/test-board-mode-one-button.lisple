(ns pixils.test.app.minesweeper.core
  (:require pixils
            [pixils.ui :as ui]))

(defcomponent board-test-button
  {:style {:width 17 :height 17}
   :on-click (fn [state event ctx]
               (when (= (:button event) :right)
                 (ui/emit! (:view ctx) :cell/toggle-flag {:x 0 :y 0}))
               state)})

(defmode board-mode
  {:children [{:mode 'board-test-button
               :style {:width 17 :height 17}}]})
