(ns asteroids.color
  (:require [pixils.color :as c]))


;; Mode Colors

(def STAT-COLOR (c/make-color {:r 255 :g 235 :b 120}))
(def VALUE-COLOR (c/make-color {:r 200 :g 200 :b 255}))
(def MUTED-COLOR (c/make-color {:r 255 :g 255 :b 255 :a 100}))
(def PAUSE-TEXT-COLOR (c/make-color {:r 255 :g 50 :b 255}))
(def PAUSE-OVERLAY-COLOR (c/make-color {:r 40 :g 0 :b 80}))
