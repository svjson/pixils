(ns pixils.examples.minesweeper.counter
  (:require pixils
            [pixils.render :as r]
            [pixils.ui :as ui]
            pixils.examples.minesweeper.text-node
            [pixils.examples.minesweeper.win :as win]))



;; Utility functions

(defun left-pad [s n pad]
  (let [s (str s)
        pad-len (- n (count s))]
    (if (> pad-len 0)
      (str (apply str (repeat pad-len pad)) s)
      s)))



;; Font and image resource

(defbundle counter {:images {:font-map "assets/score_numbers.png"}})

(deffont counter-font {:type :bitmap
                       :spacing 0
                       :resource :counter/font-map
                       :glyphs (reduce "0123456789"
                                       {}
                                       (fn [glyphs num]
                                         (let [index (int (str num))]
                                           (merge glyphs
                                                  {num {:x (* index 13)
                                                        :y 0
                                                        :w 13
                                                        :h 23}}))))})



;; Counter Component

(defcomponent counter {:update (fn [state ctx]
                                 (assoc state :text-value (left-pad (:value state) 3 "0")))
                       :style {:text {:font :font/counter-font}
                               :border {:thickness 1
                                        :line-style :solid
                                        :color win/panel-shadow
                                        :bottom {:color win/white :trim [0 1]}
                                        :right {:color win/white :trim [1 0]}}}
                       :children [{:mode 'text-node
                                   :state {:value (ui/bind-state :text-value)}}]})

